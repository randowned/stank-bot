# Ignore Claude, we have .opencode, Claude users can create symlinks
.claude

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env
.env.*
!.env.example
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Local data / secrets
data/
*.db
*.db-journal
*.db-wal
*.db-shm
logs/
*.log

# Tooling
uv.lock
.coverage
htmlcov/

# Frontend build artifacts (committed source is in git, node_modules/build are not)
web/node_modules
web/build
web/.svelte-kit
web/playwright-report
web/test-results

# Root-level accidental package-lock (web/package-lock.json is intentional)
/package-lock.json

# Playwright CLI artifacts (snapshots, screenshots, console logs)
.playwright-cli/

# Agent browser runtime artifacts
*.pid
review/

# OpenCode tooling (tracked via .opencode/skills/, not npm)
.opencode/node_modules/

# Auto-generated skills (installed by playwright-cli install --skills)
.opencode/skills/playwright-cli/

# E2E test artifacts
e2e-results.json

# IDE
.idea/
.vscode/
