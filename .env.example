# StankBot — environment configuration
# Copy to .env.local (for dev) or /etc/stankbot/stankbot.env (for systemd) and fill in.

# --- Discord Application ---
# Created in the Discord Developer Portal. Application ID 1494266000064122930 is StankBot's.
DISCORD_TOKEN=
DISCORD_APP_ID=1494266000064122930

# Global superuser who can always run /stank-admin commands, regardless of role.
# Your Discord user ID.
OWNER_ID=

# Comma-separated guild IDs for instant slash-command registration (dev only).
# Leave empty in production to register globally (takes up to 1 hour to propagate).
GUILD_IDS=

# --- Database ---
# SQLite default. For Postgres: postgresql+asyncpg://user:pass@host:5432/stankbot
DATABASE_URL=sqlite+aiosqlite:///./data/stankbot.db

# --- Web dashboard ---
# Set false to run the bot without the dashboard (headless mode).
ENABLE_WEB=true
WEB_BIND=127.0.0.1:8000

# Secret used to sign web session cookies. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEB_SECRET_KEY=

# Discord OAuth2 for dashboard login. Client ID = DISCORD_APP_ID.
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=text   # text | json
