# StankBot — dev environment configuration
# This file is committed to git (no secrets). It enables mock Discord and mock auth.
# Use ENV=dev to activate this file.

ENV=dev

# --- Discord Application ---
# Mock token — not used for real Gateway connection when MOCK_DISCORD=true.
DISCORD_TOKEN=mock-token-not-used
DISCORD_APP_ID=1494266000064122930

# Global superuser in dev mode.
OWNER_ID=111111111

# Dev guild for instant slash-command sync (irrelevant when mocked).
GUILD_IDS=123456789

# --- Mocks (only active when ENV=dev) ---
MOCK_DISCORD=true
MOCK_AUTH=true
MOCK_AUTO_EVENTS=false
MOCK_AUTO_EVENTS_INTERVAL=5
MOCK_DEFAULT_USER_ID=111111111
MOCK_DEFAULT_USER_NAME=DevUser
MOCK_DEFAULT_GUILD_ID=123456789
MOCK_DEFAULT_GUILD_NAME=Dev Server

# --- Database ---
# Separate dev DB so mock events never pollute preprod data.
DATABASE_URL=sqlite+aiosqlite:///./data/stankbot_dev.db

# --- Web dashboard ---
ENABLE_WEB=true
WEB_BIND=127.0.0.1:8000

# Dev secrets — not sensitive, only used for cookie signing in local dev.
WEB_SECRET_KEY=dev-secret-not-sensitive
OAUTH_CLIENT_SECRET=mock-oauth-not-used
OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=text
